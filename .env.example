OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEOAPIFY_API_KEY=

# NewsAPI key (free at https://newsapi.org/register)
NEWS_API_KEY=

# Demo access gate for interview reviewers.
DEMO_ADMIN_EMAIL=reviewer@eliseai.com
DEMO_ADMIN_PASSWORD=replace-me-with-a-random-password

# HMAC signing key for the demo login session cookie.
# Generate with: openssl rand -hex 32
DEMO_SESSION_SECRET=replace-me-with-a-random-hex-string

# Optional: U.S. Census API key (works without one but rate-limited).
# Get one at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Optional: comma-separated list of "good" U.S. states for the scoring rubric.
# Defaults to NY,TX,FL,CA,IL,GA,MA,WA,CO,DC if unset.
ELISE_PRIORITY_STATES=
